{
  "name": "@qninhdt/typespec-gorm",
  "version": "0.2.0",
  "description": "TypeSpec emitter that generates Go GORM model structs from schemas decorated with @qninhdt/typespec-orm.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./testing": {
      "types": "./dist/src/testing/index.d.ts",
      "import": "./dist/src/testing/index.js",
      "default": "./dist/src/testing/index.js"
    }
  },
  "files": [
    "dist/",
    "!dist/**/*.tsbuildinfo",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "alloy build",
    "clean": "rm -rf dist/",
    "watch": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "prepublishOnly": "alloy build"
  },
  "keywords": [
    "typespec",
    "emitter",
    "gorm",
    "go",
    "golang",
    "orm",
    "codegen",
    "database"
  ],
  "author": {
    "name": "Nguyen Quang Ninh",
    "email": "qndt123@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qninhdt/typespec-libraries.git",
    "directory": "packages/typespec-gorm"
  },
  "homepage": "https://github.com/qninhdt/typespec-libraries/tree/main/packages/typespec-gorm#readme",
  "bugs": {
    "url": "https://github.com/qninhdt/typespec-libraries/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@qninhdt/typespec-orm": "workspace:*"
  },
  "peerDependencies": {
    "@alloy-js/core": ">=0.22.0",
    "@alloy-js/typescript": ">=0.22.0",
    "@typespec/compiler": ">=1.0.0",
    "@typespec/emitter-framework": ">=0.15.0"
  },
  "peerDependenciesMeta": {
    "@typespec/compiler": {
      "optional": false
    },
    "@alloy-js/core": {
      "optional": false
    },
    "@alloy-js/typescript": {
      "optional": false
    },
    "@typespec/emitter-framework": {
      "optional": false
    }
  },
  "devDependencies": {
    "@alloy-js/cli": "latest",
    "@alloy-js/core": "latest",
    "@alloy-js/rollup-plugin": "latest",
    "@alloy-js/typescript": "latest",
    "@typespec/compiler": "latest",
    "@typespec/emitter-framework": "latest",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "~5.7.0",
    "vitest": "^3.0.0"
  }
}
