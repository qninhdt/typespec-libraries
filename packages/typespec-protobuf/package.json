{
  "name": "@qninhdt/typespec-protobuf",
  "version": "0.5.0",
  "description": "First-party Protobuf emitter for the openlet TypeSpec stack — ergonomic decorators, auto type mapping, cross-file imports, single-source @entity sharing with ent/sqlmodel, auto-generated buf configs.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "tspMain": "lib/main.tsp",
  "sideEffects": false,
  "exports": {
    ".": {
      "typespec": "./lib/main.tsp",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./testing": {
      "types": "./dist/src/testing/index.d.ts",
      "import": "./dist/src/testing/index.js",
      "default": "./dist/src/testing/index.js"
    }
  },
  "files": [
    "dist/",
    "!dist/**/*.tsbuildinfo",
    "lib/",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist/",
    "watch": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "prepublishOnly": "tsc -p tsconfig.build.json"
  },
  "keywords": [
    "typespec",
    "protobuf",
    "grpc",
    "emitter",
    "openlet"
  ],
  "author": {
    "name": "Nguyen Quang Ninh",
    "email": "qndt123@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qninhdt/typespec-libraries.git",
    "directory": "packages/typespec-protobuf"
  },
  "homepage": "https://github.com/qninhdt/typespec-libraries/tree/main/packages/typespec-protobuf#readme",
  "bugs": {
    "url": "https://github.com/qninhdt/typespec-libraries/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@typespec/compiler": ">=1.12.0"
  },
  "peerDependenciesMeta": {
    "@typespec/compiler": {
      "optional": false
    }
  },
  "dependencies": {
    "@qninhdt/typespec-orm": "workspace:*"
  },
  "devDependencies": {
    "@typespec/compiler": "^1.12.0",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "~5.7.0",
    "vitest": "^4.1.6"
  }
}
