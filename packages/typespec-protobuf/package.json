{
  "name": "@qninhdt/typespec-protobuf",
  "version": "0.1.0",
  "description": "TypeSpec emitter that generates Protocol Buffer (.proto) files with automatic type mapping and gRPC service support.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "tspMain": "lib/main.tsp",
  "sideEffects": false,
  "exports": {
    ".": {
      "typespec": "./lib/main.tsp",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./testing": {
      "types": "./dist/src/testing/index.d.ts",
      "import": "./dist/src/testing/index.js",
      "default": "./dist/src/testing/index.js"
    }
  },
  "files": [
    "dist/",
    "!dist/**/*.tsbuildinfo",
    "lib/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist/",
    "watch": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "prepublishOnly": "tsc -p tsconfig.build.json"
  },
  "keywords": [
    "typespec",
    "emitter",
    "protobuf",
    "proto",
    "grpc",
    "codegen"
  ],
  "author": {
    "name": "Nguyen Quang Ninh",
    "email": "qndt123@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qninhdt/typespec-libraries.git",
    "directory": "packages/typespec-protobuf"
  },
  "homepage": "https://github.com/qninhdt/typespec-libraries/tree/main/packages/typespec-protobuf#readme",
  "bugs": {
    "url": "https://github.com/qninhdt/typespec-libraries/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@qninhdt/typespec-orm": "workspace:*"
  },
  "peerDependencies": {
    "@typespec/compiler": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@typespec/compiler": {
      "optional": false
    }
  },
  "devDependencies": {
    "@typespec/compiler": "^1.12.0",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6"
  }
}
