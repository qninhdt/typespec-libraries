// Database Schema

// Namespace: FileVault.Assistant

Enum ApprovalDecision {
  pending
  approved
  rejected
}

Enum ConversationState {
  active
  archived
}

Enum MessageRole {
  user
  assistant
  system
}

Enum AssistantTaskStatus {
  queued
  running
  waitingForApproval
  completed
  failed
  canceled
}

Table assistant_approvals {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  task_id uuid [not null]
  action varchar(160) [not null]
  resource_type varchar(80) [not null]
  resource_id uuid [not null]
  proposal_json jsonb [not null]
  decision ApprovalDecision [not null, default: 'pending']
  decided_by uuid
  decided_at timestamptz

  indexes {
    task_id
  }
}

Table assistant_conversations {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
  owner_id uuid [not null]
  title varchar(200) [not null]
  state ConversationState [not null, default: 'active']
  last_message_at timestamptz

  indexes {
    owner_id
  }
}

Table assistant_messages {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  conversation_id uuid [not null]
  role MessageRole [not null]
  content text [not null]
  model_name varchar(120)
  token_count integer

  indexes {
    conversation_id
  }
}

Table assistant_tasks {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  conversation_id uuid [not null]
  requested_by uuid [not null]
  task_type varchar(120) [not null]
  objective text [not null]
  status AssistantTaskStatus [not null, default: 'queued']
  target_node_id uuid
  result_summary text
  started_at timestamptz
  finished_at timestamptz

  indexes {
    conversation_id
    requested_by
  }
}


// Namespace: FileVault.Audit

Enum AuditSeverity {
  info
  warning
  critical
}

Table audit_events {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  actor_id uuid
  action varchar(160) [not null]
  resource_type varchar(80) [not null]
  resource_id uuid
  severity AuditSeverity [not null, default: 'info']
  request_id text
  ip_address_hash text
  user_agent_hash text
  metadata_json jsonb

  indexes {
    actor_id
  }
}

Table audit_export_checkpoints {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  sink_name text [not null]
  last_event_id uuid
  exported_at timestamptz

  indexes {
    sink_name [unique]
  }
}


// Namespace: FileVault.Identity

Enum ExternalAuthProvider {
  google
  github
  apple
  microsoft
}

Enum MfaFactorKind {
  totp
  webauthn
  recoveryCode
}

Enum AccountStatus {
  active
  disabled
  pendingVerification
}

Table auth_sessions {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  account_id uuid [not null]
  refresh_token_hash text [not null]
  device_label varchar(80)
  ip_address_hash varchar(128)
  user_agent_hash varchar(128)
  expires_at timestamptz [not null]
  revoked_at timestamptz

  indexes {
    account_id
    refresh_token_hash [unique]
  }
}

Table external_identities {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  account_id uuid [not null]
  provider ExternalAuthProvider [not null]
  provider_subject varchar(256) [not null]
  email_at_provider varchar(320)
  linked_at timestamptz [not null]

  indexes {
    (provider, provider_subject) [unique]
    account_id
  }
}

Table mfa_factors {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  account_id uuid [not null]
  kind MfaFactorKind [not null]
  label varchar(120)
  secret_ref text [not null]
  verified_at timestamptz
  disabled_at timestamptz

  indexes {
    account_id
  }
}

Table password_credentials {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  account_id uuid [not null]
  password_hash text [not null]
  password_algorithm varchar(64) [not null]
  password_updated_at timestamptz [not null]
  compromised_at timestamptz

  indexes {
    account_id [unique]
  }
}

Table user_accounts {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
  email varchar(320) [not null]
  display_name varchar(120) [not null]
  avatar_url varchar(512)
  locale varchar(16)
  status AccountStatus [not null, default: 'pendingVerification']
  email_verified_at timestamptz
  last_login_at timestamptz
  disabled_at timestamptz

  indexes {
    email [unique]
    status
  }
}


// Namespace: FileVault.Metadata

Enum FileCategory {
  unspecified
  document
  image
  audio
  video
  archive
}

Enum VaultNodeKind {
  folder
  file
}

Enum VaultNodeState {
  active
  trashed
  deleted
}

Enum Visibility {
  private
  shared
  publicLink
}

Table file_labels {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
  vault_id uuid [not null]
  name varchar(80) [not null]
  color varchar(16)

  indexes {
    (vault_id, name) [unique]
    vault_id
  }
}

Table file_label_assignments {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  file_id uuid [not null]
  label_id uuid [not null]

  indexes {
    (file_id, label_id) [unique]
    file_id
    label_id
  }
}

Table file_metadata {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  node_id uuid [not null]
  current_version_id uuid
  category FileCategory [not null, default: 'unspecified']
  media_type varchar(160) [not null]
  extension varchar(32)
  size_bytes bigint [not null]
  sha256 varchar(128) [not null]

  indexes {
    node_id [unique]
    current_version_id
  }
}

Table file_versions {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  file_id uuid [not null]
  version_number integer [not null]
  storage_object_id uuid [not null]
  size_bytes bigint [not null]
  sha256 varchar(128) [not null]
  created_by uuid [not null]

  indexes {
    (file_id, version_number) [unique]
    file_id
    storage_object_id
    created_by
  }
}

Table vault_nodes {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
  vault_id uuid [not null]
  parent_id uuid
  kind VaultNodeKind [not null]
  name varchar(240) [not null]
  normalized_name varchar(240) [not null]
  path text [not null]
  depth integer [not null]
  state VaultNodeState [not null, default: 'active']
  visibility Visibility [not null, default: 'private']
  trashed_at timestamptz
  created_by uuid [not null]
  updated_by uuid

  indexes {
    (vault_id, parent_id, normalized_name) [unique]
    vault_id
    parent_id
    state
    created_by
  }
}

Table vault_spaces {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  deleted_at timestamptz
  owner_id uuid [not null]
  name varchar(120) [not null]
  quota_bytes bigint [not null]
  used_bytes bigint [not null, default: `0`]

  indexes {
    owner_id
  }
}


// Namespace: FileVault.Notifications

Enum NotificationChannel {
  inApp
  email
  webhook
}

Enum NotificationState {
  queued
  sent
  failed
}

Table notifications {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  recipient_id uuid [not null]
  subject varchar(160) [not null]
  body text [not null]
  resource_type text
  resource_id uuid
  read_at timestamptz

  indexes {
    recipient_id
  }
}

Table notification_deliveries {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  notification_id uuid [not null]
  channel NotificationChannel [not null]
  state NotificationState [not null, default: 'queued']
  provider_message_id text
  error_message text
  sent_at timestamptz

  indexes {
    notification_id
  }
}

Table notification_preferences {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  account_id uuid [not null]
  channel NotificationChannel [not null]
  enabled boolean [not null, default: `true`]
  quiet_hours_json jsonb

  indexes {
    (account_id, channel) [unique]
    account_id
  }
}


// Namespace: FileVault.Processing

Enum ArtifactKind {
  extractedText
  summary
  previewImage
  thumbnail
  classification
}

Enum ProcessingKind {
  classify
  extractText
  summarize
  generatePreview
  scanMalware
}

Enum ProcessingStatus {
  queued
  running
  succeeded
  failed
  canceled
}

Table extracted_texts {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  file_id uuid [not null]
  language text
  content text [not null]
  extraction_version integer [not null, default: `1`]

  indexes {
    file_id [unique]
  }
}

Table file_summaries {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  file_id uuid [not null]
  summary text [not null]
  model_name text [not null]
  generated_at timestamptz [not null]

  indexes {
    file_id [unique]
  }
}

Table processing_artifacts {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  job_id uuid [not null]
  file_id uuid [not null]
  kind ArtifactKind [not null]
  storage_object_id uuid
  text_value text
  metadata_json jsonb

  indexes {
    job_id
    file_id
  }
}

Table processing_jobs {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  file_id uuid [not null]
  version_id uuid
  kind ProcessingKind [not null]
  status ProcessingStatus [not null, default: 'queued']
  priority integer [not null, default: `100`]
  attempts integer [not null, default: `0`]
  scheduled_at timestamptz [not null]
  started_at timestamptz
  finished_at timestamptz
  error_message varchar(512)
  parameters_json jsonb

  indexes {
    file_id
    version_id
    status
  }
}


// Namespace: FileVault.Search

Enum IndexState {
  pending
  indexed
  failed
  removed
}

Table search_documents {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  file_id uuid [not null]
  owner_id uuid [not null]
  title varchar(240) [not null]
  media_type text [not null]
  language text
  state IndexState [not null, default: 'pending']
  indexed_at timestamptz
  content_version integer [not null, default: `1`]
  tags_json jsonb

  indexes {
    file_id [unique]
    owner_id
  }
}

Table search_index_checkpoints {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  shard_key text [not null]
  last_processed_event_id text
  last_processed_at timestamptz

  indexes {
    shard_key [unique]
  }
}


// Namespace: FileVault.Sharing

Enum ShareSubjectKind {
  account
  email
  organization
}

Enum ShareRole {
  viewer
  commenter
  editor
}

Table share_grants {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  resource_node_id uuid [not null]
  granted_by uuid [not null]
  subject_kind ShareSubjectKind [not null]
  subject varchar(320) [not null]
  role ShareRole [not null]
  expires_at timestamptz
  revoked_at timestamptz

  indexes {
    resource_node_id
    granted_by
  }
}

Table share_links {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  resource_node_id uuid [not null]
  created_by uuid [not null]
  token_hash text [not null]
  role ShareRole [not null, default: 'viewer']
  password_hash text
  max_downloads integer
  download_count integer [not null, default: `0`]
  expires_at timestamptz
  revoked_at timestamptz

  indexes {
    resource_node_id
    created_by
    token_hash [unique]
  }
}


// Namespace: FileVault.Storage

Enum StorageObjectState {
  pending
  available
  quarantined
  deleted
}

Enum UploadState {
  initiated
  receiving
  completed
  aborted
  expired
}

Table storage_buckets {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  name varchar(120) [not null]
  provider varchar(80) [not null]
  region varchar(80) [not null]
  default_encryption boolean [not null, default: `true`]

  indexes {
    name [unique]
  }
}

Table storage_objects {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  bucket_id uuid [not null]
  object_key text [not null]
  size_bytes bigint [not null]
  sha256 varchar(128) [not null]
  media_type varchar(160) [not null]
  state StorageObjectState [not null, default: 'pending']
  encryption_key_ref text

  indexes {
    bucket_id
    object_key [unique]
  }
}

Table upload_parts {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  upload_session_id uuid [not null]
  part_number integer [not null]
  offset_bytes bigint [not null]
  size_bytes bigint [not null]
  sha256 varchar(128) [not null]

  indexes {
    (upload_session_id, part_number) [unique]
    upload_session_id
  }
}

Table upload_sessions {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [default: `now()`]
  account_id uuid [not null]
  bucket_id uuid [not null]
  storage_object_id uuid
  file_name varchar(240) [not null]
  expected_size_bytes bigint [not null]
  state UploadState [not null, default: 'initiated']
  expires_at timestamptz [not null]
  completed_at timestamptz

  indexes {
    account_id
    bucket_id
    storage_object_id
  }
}


Ref: assistant_approvals.task_id > assistant_tasks.id [delete: CASCADE]
Ref: assistant_conversations.owner_id > user_accounts.id [delete: CASCADE]
Ref: assistant_messages.conversation_id > assistant_conversations.id [delete: CASCADE]
Ref: assistant_tasks.conversation_id > assistant_conversations.id [delete: CASCADE]
Ref: assistant_tasks.requested_by > user_accounts.id
Ref: auth_sessions.account_id > user_accounts.id [delete: CASCADE]
Ref: external_identities.account_id > user_accounts.id [delete: CASCADE]
Ref: extracted_texts.file_id - file_metadata.id [delete: CASCADE]
Ref: file_label_assignments.file_id > file_metadata.id [delete: CASCADE]
Ref: file_label_assignments.label_id > file_labels.id [delete: CASCADE]
Ref: file_labels.vault_id > vault_spaces.id [delete: CASCADE]
Ref: file_metadata.node_id - vault_nodes.id [delete: CASCADE]
Ref: file_summaries.file_id - file_metadata.id [delete: CASCADE]
Ref: file_versions.created_by > user_accounts.id
Ref: file_versions.file_id > file_metadata.id [delete: CASCADE]
Ref: mfa_factors.account_id > user_accounts.id [delete: CASCADE]
Ref: notification_deliveries.notification_id > notifications.id [delete: CASCADE]
Ref: notification_preferences.account_id > user_accounts.id [delete: CASCADE]
Ref: notifications.recipient_id > user_accounts.id [delete: CASCADE]
Ref: password_credentials.account_id - user_accounts.id [delete: CASCADE]
Ref: processing_artifacts.file_id > file_metadata.id [delete: CASCADE]
Ref: processing_artifacts.job_id > processing_jobs.id [delete: CASCADE]
Ref: processing_jobs.file_id > file_metadata.id [delete: CASCADE]
Ref: search_documents.file_id - file_metadata.id [delete: CASCADE]
Ref: search_documents.owner_id > user_accounts.id [delete: CASCADE]
Ref: share_grants.granted_by > user_accounts.id
Ref: share_grants.resource_node_id > vault_nodes.id [delete: CASCADE]
Ref: share_links.created_by > user_accounts.id
Ref: share_links.resource_node_id > vault_nodes.id [delete: CASCADE]
Ref: storage_objects.bucket_id > storage_buckets.id [delete: RESTRICT]
Ref: upload_parts.upload_session_id > upload_sessions.id [delete: CASCADE]
Ref: upload_sessions.account_id > user_accounts.id [delete: CASCADE]
Ref: upload_sessions.bucket_id > storage_buckets.id
Ref: vault_nodes.created_by > user_accounts.id
Ref: vault_nodes.vault_id > vault_spaces.id [delete: CASCADE]
Ref: vault_spaces.owner_id > user_accounts.id [delete: CASCADE]
