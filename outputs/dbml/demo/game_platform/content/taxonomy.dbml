// Database Schema

// Namespace: Demo.GamePlatform.Content.Taxonomy

Table tags {
  id uuid [pk, not null, note: 'Unique identifier shared by most persisted records.']
  created_at timestamp [not null, default: 'now()', note: 'Timestamp when the record was created.']
  updated_at timestamp [note: 'Timestamp of the last update.']
  deleted_at timestamp [note: 'Soft delete marker for archival workflows.']
  world_id uuid [not null, note: 'Foreign key to the owning world.']
  name varchar(100) [not null, note: 'Tag name - unique within a world.']
  category varchar(50) [not null, note: 'Category used to group related tags.']

  indexes {
    (world_id, name) [unique]
    world_id
    category
  }
}


Ref: tags.world_id > worlds.id [delete: CASCADE, update: CASCADE]
